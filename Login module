<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Farmer Query Advisory Login</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:linear-gradient(135deg,#2E7D32,#66BB6A);
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

.login-container{
    background:white;
    width:380px;
    padding:35px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
    text-align:center;
}

.logo{
    font-size:60px;
}

h2{
    color:#2E7D32;
    margin-bottom:10px;
}

.subtitle{
    color:#666;
    font-size:14px;
    margin-bottom:25px;
}

.input-group{
    margin-bottom:15px;
}

input{
    width:100%;
    padding:12px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:15px;
}

input:focus{
    outline:none;
    border-color:#4CAF50;
}

.btn{
    width:100%;
    background:#2E7D32;
    color:white;
    border:none;
    padding:12px;
    border-radius:8px;
    font-size:16px;
    cursor:pointer;
    margin-top:10px;
}

.btn:hover{
    background:#1B5E20;
}

.links{
    margin-top:15px;
    font-size:14px;
}

.links a{
    color:#2E7D32;
    text-decoration:none;
    font-weight:bold;
}
</style>

</head>
<body>

<div class="login-container">

    <div class="logo">🌱</div>

    <h2>AI Farmer Query Support</h2>

    <p class="subtitle">
        Smart Agricultural Advisory System
    </p>

    <form>

        <div class="input-group">
            <input type="email"
            placeholder="Email Address"
            required>
        </div>

        <div class="input-group">
            <input type="password"
            placeholder="Password"
            required>
        </div>

        <button class="btn">
            Login
        </button>

    </form>

    <div class="links">
        Don't have an account?
        <a href="#">Register Here</a>
    </div>

</div>

</body>
</html>
